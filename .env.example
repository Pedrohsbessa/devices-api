# Copy this file to `.env` and edit the values. docker compose picks it up
# automatically; Makefile targets `include` it too. `.env` itself is in
# .gitignore so secrets do not end up in the repository.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
POSTGRES_USER=devices
POSTGRES_PASSWORD=devices
POSTGRES_DB=devices

# Host port Postgres is published on. Change if 5432 is already in use
# locally.
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# HTTP server
# ---------------------------------------------------------------------------
# Host port the API is published on. Inside the container the server
# always listens on :8080.
HTTP_PORT=8080

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# debug | info | warn | error
LOG_LEVEL=info

# json | text
LOG_FORMAT=json
